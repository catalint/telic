{
	"name": "@telic/core",
	"version": "0.4.0",
	"description": "A recorded intent + memory layer for frontends: record typed user-intent lifecycles (begun → fulfilled/rejected/abandoned) beside any state management, query them as in-page session memory, and optionally mediate cross-domain invocation (handle/dispatch, flow sagas). Zero dependencies.",
	"license": "MIT",
	"author": {
		"name": "Catalin Tanasescu",
		"email": "catalint@gmail.com",
		"url": "https://github.com/catalint"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/core.js",
	"types": "./dist/core.d.ts",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/catalint/telic.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/catalint/telic#readme",
	"bugs": "https://github.com/catalint/telic/issues",
	"keywords": [
		"intent",
		"user-intent",
		"state",
		"observability",
		"analytics",
		"breadcrumbs",
		"session-memory",
		"micro-frontends",
		"islands",
		"ai-agents",
		"typescript",
		"frontend",
		"saga",
		"abandonment",
		"funnel"
	],
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md",
		"AI-GUIDE.md",
		"SPEC.md",
		"DESIGN.md",
		"PATTERNS.md",
		"APPROACHES.md",
		"DECISIONS.md"
	],
	"exports": {
		".": {
			"types": "./dist/core.d.ts",
			"default": "./dist/core.js"
		},
		"./taps/console": {
			"types": "./dist/taps/console.d.ts",
			"default": "./dist/taps/console.js"
		},
		"./taps/breadcrumbs": {
			"types": "./dist/taps/breadcrumbs.d.ts",
			"default": "./dist/taps/breadcrumbs.js"
		},
		"./taps/sentry": {
			"types": "./dist/taps/sentry.d.ts",
			"default": "./dist/taps/sentry.js"
		},
		"./taps/user-timing": {
			"types": "./dist/taps/user-timing.d.ts",
			"default": "./dist/taps/user-timing.js"
		},
		"./taps/analytics": {
			"types": "./dist/taps/analytics.d.ts",
			"default": "./dist/taps/analytics.js"
		},
		"./agent": {
			"types": "./dist/agent/surface.d.ts",
			"default": "./dist/agent/surface.js"
		},
		"./mediate": {
			"types": "./dist/mediate.d.ts",
			"default": "./dist/mediate.js"
		},
		"./flow": {
			"types": "./dist/flow.d.ts",
			"default": "./dist/flow.js"
		},
		"./persist": {
			"types": "./dist/persist.d.ts",
			"default": "./dist/persist.js"
		},
		"./wire": {
			"types": "./dist/wire.d.ts",
			"default": "./dist/wire.js"
		},
		"./testing": {
			"types": "./dist/testing.d.ts",
			"default": "./dist/testing.js"
		},
		"./adapters/tanstack-query": {
			"types": "./dist/adapters/tanstack-query.d.ts",
			"default": "./dist/adapters/tanstack-query.js"
		},
		"./transports/broadcast": {
			"types": "./dist/transports/broadcast.d.ts",
			"default": "./dist/transports/broadcast.js"
		},
		"./transports/post-message": {
			"types": "./dist/transports/post-message.d.ts",
			"default": "./dist/transports/post-message.js"
		},
		"./transports/shared-worker": {
			"types": "./dist/transports/shared-worker.d.ts",
			"default": "./dist/transports/shared-worker.js"
		},
		"./transports/remote-dispatch": {
			"types": "./dist/transports/remote-dispatch.d.ts",
			"default": "./dist/transports/remote-dispatch.js"
		},
		"./adapters/xstate": {
			"types": "./dist/adapters/xstate.d.ts",
			"default": "./dist/adapters/xstate.js"
		},
		"./devtools": {
			"types": "./dist/devtools.d.ts",
			"default": "./dist/devtools.js"
		},
		"./taps/otel": {
			"types": "./dist/taps/otel.d.ts",
			"default": "./dist/taps/otel.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "bun test src/",
		"size": "bun scripts/size-gate.ts",
		"prepack": "bun run build"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"typescript": "^7.0.0",
		"@tanstack/query-core": "^5.90.0",
		"xstate": "^5.32.0"
	}
}
