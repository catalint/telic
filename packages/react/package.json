{
	"name": "@telic/react",
	"version": "0.1.0",
	"description": "React adapter for @telic/core — stable intent handles, presence-based mediation handles, and useSyncExternalStore memory hooks. Mounts are not intents.",
	"license": "MIT",
	"author": "Catalin Tanasescu",
	"type": "module",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/catalint/telic.git",
		"directory": "packages/react"
	},
	"homepage": "https://github.com/catalint/telic#readme",
	"bugs": "https://github.com/catalint/telic/issues",
	"keywords": [
		"react",
		"hooks",
		"intent",
		"user-intent",
		"state",
		"observability",
		"session-memory",
		"useSyncExternalStore"
	],
	"publishConfig": {
		"access": "public"
	},
	"files": ["dist", "README.md", "SPEC.md"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "bun test src/",
		"prepack": "bun run build"
	},
	"peerDependencies": {
		"react": ">=18",
		"@telic/core": "workspace:^"
	},
	"devDependencies": {
		"@happy-dom/global-registrator": "^20.10.6",
		"@telic/core": "workspace:*",
		"@types/bun": "^1.3.14",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"typescript": "^7.0.0"
	}
}
