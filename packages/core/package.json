{
	"name": "@telic/core",
	"version": "0.1.0",
	"description": "A recorded intent + memory layer for frontends — record-first user-intent lifecycle with in-page queryable session memory.",
	"license": "MIT",
	"author": "Catalin Tanasescu",
	"type": "module",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/catalint/telic.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/catalint/telic#readme",
	"bugs": "https://github.com/catalint/telic/issues",
	"keywords": [
		"intent",
		"user-intent",
		"state",
		"observability",
		"analytics",
		"breadcrumbs",
		"session-memory",
		"micro-frontends",
		"islands",
		"ai-agents"
	],
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md",
		"SPEC.md",
		"DESIGN.md",
		"PATTERNS.md",
		"APPROACHES.md",
		"DECISIONS.md"
	],
	"exports": {
		".": {
			"types": "./dist/core.d.ts",
			"default": "./dist/core.js"
		},
		"./taps/console": {
			"types": "./dist/taps/console.d.ts",
			"default": "./dist/taps/console.js"
		},
		"./taps/breadcrumbs": {
			"types": "./dist/taps/breadcrumbs.d.ts",
			"default": "./dist/taps/breadcrumbs.js"
		},
		"./taps/sentry": {
			"types": "./dist/taps/sentry.d.ts",
			"default": "./dist/taps/sentry.js"
		},
		"./taps/user-timing": {
			"types": "./dist/taps/user-timing.d.ts",
			"default": "./dist/taps/user-timing.js"
		},
		"./taps/analytics": {
			"types": "./dist/taps/analytics.d.ts",
			"default": "./dist/taps/analytics.js"
		},
		"./agent": {
			"types": "./dist/agent/surface.d.ts",
			"default": "./dist/agent/surface.js"
		},
		"./mediate": {
			"types": "./dist/mediate.d.ts",
			"default": "./dist/mediate.js"
		},
		"./flow": {
			"types": "./dist/flow.d.ts",
			"default": "./dist/flow.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "bun test src/",
		"size": "bun scripts/size-gate.ts",
		"prepack": "bun run build"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"typescript": "^6.0.3"
	}
}
